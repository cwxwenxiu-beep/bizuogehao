<script>
  var btn = document.getElementById('menuBtn');
  var nav = document.getElementById('mobileNav');
  btn.addEventListener('click', function() { nav.classList.toggle('open'); });
  function closeMobile() { nav.classList.remove('open'); }
</script>
</body>
</html>
