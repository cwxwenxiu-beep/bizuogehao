  <style>
    :root {
      --ink:      #15171c;
      --muted:    #6b7280;
      --line:     #e5e7eb;
      --soft:     #f6f7f9;
      --red:      #ce3b2b;
      --red-deep: #9f291f;
      --blue:     #2563eb;
      --green:    #16a34a;
      --amber:    #d97706;
      --shadow:   0 22px 70px rgba(17,24,39,.12);
      --radius:   8px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0; color: var(--ink); background: #fff;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    .container { width: min(1160px, calc(100% - 40px)); margin: 0 auto; }

    /* ── NAV ───────────────────────────────────────────── */
    .site-header {
      position: sticky; top: 0; z-index: 20;
      background: rgba(255,255,255,.94);
      border-bottom: 1px solid rgba(229,231,235,.9);
      backdrop-filter: blur(16px);
    }
    .nav {
      height: 68px; display: flex; align-items: center;
      justify-content: space-between; gap: 24px;
    }
    .brand { display: flex; align-items: center; gap: 10px; }
    .brand img { width: 32px; height: 32px; }
    .brand strong { display: block; font-size: 14px; line-height: 1.1; }
    .brand em     { display: block; color: var(--muted); font-size: 11px; margin-top: 2px; font-style: normal; }
    .nav-links {
      display: flex; align-items: center; gap: 20px;
      color: #4b5563; font-size: 13px; white-space: nowrap;
    }
    .nav-links a:hover { color: var(--red); }
    .lang-toggle {
      padding: 4px 10px; border-radius: 4px;
      border: 1px solid var(--line); font-size: 12px; color: var(--muted);
    }
    .lang-toggle:hover { border-color: var(--red); color: var(--red); }
    .nav-cta {
      display: inline-flex; align-items: center; justify-content: center;
      min-height: 36px; padding: 0 16px;
      color: white; background: var(--ink); border-radius: 6px;
      font-size: 13px; font-weight: 700; white-space: nowrap;
    }
    .nav-cta:hover { background: #2d3748; }
    .menu-toggle {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: none; cursor: pointer; padding: 4px;
    }
    .menu-toggle span { display: block; width: 22px; height: 2px; background: var(--ink); border-radius: 2px; }
    .mobile-nav {
      display: none; flex-direction: column;
      border-top: 1px solid var(--line); background: #fff;
    }
    .mobile-nav a {
      display: block; padding: 13px 20px; font-size: 14px;
      border-bottom: 1px solid var(--line); color: var(--ink);
    }
    .mobile-nav a:hover { color: var(--red); background: var(--soft); }
    .mobile-nav.open { display: flex; }

    /* ── HERO ──────────────────────────────────────────── */
    .hero {
      padding: 72px 0 52px;
      background: linear-gradient(180deg, #fff 0%, #f7f8fa 100%);
      border-bottom: 1px solid var(--line);
    }
    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(400px, .95fr);
      gap: 48px; align-items: center;
    }
    .eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      color: var(--red); font-size: 12px; font-weight: 800; text-transform: uppercase;
    }
    .eyebrow::before {
      content: ""; width: 7px; height: 7px;
      border-radius: 999px; background: var(--red);
    }
    h1 {
      margin: 16px 0 16px; max-width: 720px;
      font-size: clamp(40px, 5.5vw, 68px);
      line-height: .92; font-weight: 900;
    }
    .accent { color: var(--red); }
    .hero-lead { max-width: 580px; margin: 0; color: #4b5563; font-size: 17px; line-height: 1.65; }
    .hero-actions { display: flex; align-items: center; gap: 12px; margin: 28px 0 26px; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      min-height: 46px; padding: 0 18px; border-radius: 7px;
      font-size: 14px; font-weight: 800; border: 1px solid transparent;
      transition: transform .18s ease, background .18s ease;
    }
    .btn:hover { transform: translateY(-1px); }
    .btn-primary   { color: white; background: var(--red); box-shadow: 0 14px 30px rgba(206,59,43,.22); }
    .btn-primary:hover { background: var(--red-deep); }
    .btn-secondary { color: var(--ink); background: white; border-color: #d1d5db; }
    .btn-secondary:hover { border-color: #9ca3af; }
    .stats-row { display: flex; gap: 20px; flex-wrap: wrap; }
    .stat {
      padding: 12px 14px; border: 1px solid var(--line);
      background: rgba(255,255,255,.82); border-radius: var(--radius); min-width: 110px;
    }
    .stat b    { display: block; font-size: 22px; color: var(--ink); }
    .stat span { display: block; margin-top: 2px; color: var(--muted); font-size: 11px; line-height: 1.35; }

    /* ── STUDIO BOARD ──────────────────────────────────── */
    .studio-board {
      position: relative; min-height: 560px;
      border-radius: 16px; padding: 16px;
      background: #111318; box-shadow: var(--shadow); overflow: hidden;
    }
    .studio-board::before {
      content: ""; position: absolute; inset: 0;
      background:
        radial-gradient(circle at 18% 12%, rgba(206,59,43,.28), transparent 28%),
        radial-gradient(circle at 88% 8%,  rgba(37,99,235,.22),  transparent 30%),
        linear-gradient(135deg, rgba(255,255,255,.06), transparent 38%);
      pointer-events: none;
    }
    .board-top {
      position: relative; display: flex; justify-content: space-between;
      align-items: center; margin-bottom: 14px; color: white; font-size: 11px;
    }
    .board-live {
      color: #86efac; background: rgba(22,163,74,.14);
      padding: 4px 8px; border-radius: 999px; border: 1px solid rgba(134,239,172,.28);
    }
    .visual-grid { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .phone {
      min-height: 400px; border-radius: 16px; overflow: hidden;
      background: #222; border: 1px solid rgba(255,255,255,.12);
      box-shadow: 0 16px 40px rgba(0,0,0,.32);
    }
    .phone img { width: 100%; height: 100%; min-height: 400px; object-fit: cover; }
    .right-stack { display: grid; gap: 12px; }
    .mini-panel {
      border-radius: 10px; background: rgba(255,255,255,.95);
      border: 1px solid rgba(255,255,255,.22); padding: 12px;
    }
    .mini-panel.dark {
      color: white; background: rgba(20,24,31,.82); border-color: rgba(255,255,255,.14);
    }
    .mini-title {
      display: flex; justify-content: space-between; align-items: center;
      font-size: 11px; font-weight: 800; margin-bottom: 10px;
    }
    .mini-title em { color: var(--green); font-style: normal; }
    .poster-strip { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; }
    .poster-tile  { aspect-ratio: 3/4; border-radius: 6px; background: #f3f4f6; overflow: hidden; }
    .poster-tile img { width: 100%; height: 100%; object-fit: cover; }
    .script-lines { display: grid; gap: 6px; color: #d1d5db; font-size: 11px; line-height: 1.4; }
    .script-lines span {
      display: block; padding: 8px 10px; border-radius: 6px;
      background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.08);
    }
    .metric-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 7px; }
    .metric      { padding: 9px; border-radius: 6px; background: #f3f4f6; }
    .metric b    { display: block; font-size: 16px; }
    .metric span { color: var(--muted); font-size: 11px; }
    .caption-card {
      position: absolute; left: 28px; right: 28px; bottom: 26px;
      color: white; padding: 10px 12px; border-radius: 9px;
      background: rgba(0,0,0,.68); border: 1px solid rgba(255,255,255,.18);
      backdrop-filter: blur(10px); font-size: 12px; line-height: 1.5;
    }

    /* ── PLATFORM BAR ──────────────────────────────────── */
    .platform-bar { background: var(--soft); border-bottom: 1px solid var(--line); padding: 16px 0; }
    .platform-bar-inner {
      display: flex; align-items: center; gap: 24px;
      flex-wrap: wrap; justify-content: center;
    }
    .platform-bar .bar-label { font-size: 11px; color: var(--muted); font-weight: 700; text-transform: uppercase; }
    .plat-chip {
      padding: 6px 14px; border-radius: 999px; border: 1px solid var(--line);
      background: white; font-size: 13px; font-weight: 700; color: #374151;
    }

    /* ── SECTIONS ──────────────────────────────────────── */
    section { padding: 68px 0; }
    .section-head { display: flex; justify-content: space-between; gap: 32px; align-items: end; margin-bottom: 28px; }
    .section-head h2 { margin: 10px 0 0; font-size: clamp(28px, 4vw, 46px); line-height: 1; }
    .section-head p  { max-width: 420px; margin: 0; color: var(--muted); line-height: 1.6; }

    /* ── SERVICES ──────────────────────────────────────── */
    .services { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .service {
      padding: 24px; border: 1px solid var(--line);
      border-radius: var(--radius); background: white;
    }
    .service:nth-child(1) { border-top: 3px solid var(--red); }
    .service:nth-child(2) { border-top: 3px solid var(--blue); }
    .service:nth-child(3) { border-top: 3px solid var(--green); }
    .service:nth-child(4) { border-top: 3px solid var(--amber); }
    .service .snum { color: var(--muted); font-size: 11px; font-weight: 800; }
    .service h3 { margin: 18px 0 9px; font-size: 20px; }
    .service p  { margin: 0; color: var(--muted); line-height: 1.6; font-size: 14px; }
    .svc-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
    .svc-tags span {
      padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 700;
      background: #f3f4f6; color: #374151;
    }

    /* ── DRAMA SLATE ───────────────────────────────────── */
    .drama-band { background: #0d0f14; color: white; }
    .drama-band .eyebrow { color: #f87171; }
    .drama-band .eyebrow::before { background: #f87171; }
    .drama-band .section-head h2 { color: white; }
    .drama-band .section-head p  { color: #9ca3af; }
    .feature-card {
      display: grid; grid-template-columns: 200px 1fr; gap: 28px;
      align-items: center; margin-bottom: 28px;
      padding: 22px; border-radius: 12px;
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    }
    .feature-card img { border-radius: 10px; width: 200px; height: 280px; object-fit: cover; }
    .genre-tag {
      display: inline-block; padding: 4px 10px; border-radius: 999px;
      background: rgba(206,59,43,.22); border: 1px solid rgba(206,59,43,.5);
      color: #fca5a5; font-size: 11px; font-weight: 700; margin-bottom: 10px;
    }
    .feature-card h3 { margin: 0 0 6px; font-size: 26px; color: white; }
    .feature-card .subtitle { color: #9ca3af; margin-bottom: 12px; font-size: 14px; }
    .feature-card p { color: #d1d5db; line-height: 1.6; font-size: 14px; margin: 0 0 14px; }
    .feature-card .tagline { font-style: italic; color: #f9fafb; font-size: 13px; }
    .poster-wall { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; }
    .drama-poster {
      position: relative; aspect-ratio: 3/4; border-radius: 8px; overflow: hidden;
      border: 1px solid rgba(255,255,255,.1); background: #1a1d24;
    }
    .drama-poster img { width: 100%; height: 100%; object-fit: cover; }
    .live-badge {
      position: absolute; top: 8px; left: 8px;
      display: flex; align-items: center; gap: 5px;
      padding: 3px 8px; border-radius: 999px;
      background: rgba(22,163,74,.2); border: 1px solid rgba(22,163,74,.5);
      color: #86efac; font-size: 10px; font-weight: 700;
    }
    .live-badge i {
      width: 6px; height: 6px; border-radius: 999px; background: #4ade80;
      animation: blink 1.2s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
    .total-badge {
      margin-top: 18px; padding: 14px 20px; border-radius: 10px;
      background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1);
      display: flex; align-items: center; gap: 14px; color: #d1d5db; font-size: 14px;
    }
    .total-badge b { font-size: 32px; color: white; }

    /* ── DISTRIBUTION ──────────────────────────────────── */
    .dist-band { background: var(--soft); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .dist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 36px; align-items: center; }
    .dist-copy h2 { font-size: clamp(26px, 3.5vw, 42px); line-height: 1.05; margin: 10px 0 14px; }
    .dist-copy p { color: var(--muted); line-height: 1.65; font-size: 15px; }
    .chip-label { font-size: 11px; font-weight: 800; text-transform: uppercase; color: var(--muted); margin-bottom: 7px; margin-top: 16px; }
    .mkt-chips  { display: flex; flex-wrap: wrap; gap: 8px; }
    .mkt-chips span {
      padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 700;
      background: white; border: 1px solid var(--line); color: var(--ink);
    }
    .plat-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .plat-chips span {
      padding: 6px 12px; border-radius: 6px; font-size: 13px; font-weight: 700;
      background: var(--ink); color: white;
    }
    .dist-visual {
      padding: 24px; background: #111318; border-radius: 14px; box-shadow: var(--shadow);
    }
    .dist-visual svg { width: 100%; height: auto; }
    .dline path { fill: none; stroke: rgba(206,59,43,.4); stroke-width: 1.5; stroke-dasharray: 5 4; }
    .src-circle { fill: var(--red); }
    .src-t { fill: white; font-size: 13px; font-weight: 800; font-family: Inter,sans-serif; }
    .src-s { fill: rgba(255,255,255,.7); font-size: 9px; font-family: Inter,sans-serif; }
    .mkt-dot  { fill: #4ade80; }
    .mkt-text { fill: #d1d5db; font-size: 11px; font-family: Inter,sans-serif; }

    /* ── WORKFLOW ──────────────────────────────────────── */
    .process-band { background: var(--soft); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .process { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }
    .step { min-height: 160px; padding: 20px; border: 1px solid var(--line); border-radius: var(--radius); background: white; }
    .step b { display: block; font-size: 26px; color: var(--red); }
    .step h3 { margin: 20px 0 8px; font-size: 17px; }
    .step p  { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.5; }

    /* ── ABOUT ─────────────────────────────────────────── */
    .about-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: 40px; align-items: start; }
    .about-copy h2 { font-size: clamp(28px, 4vw, 44px); line-height: 1.05; margin: 0 0 16px; }
    .about-copy p  { color: var(--muted); line-height: 1.7; font-size: 15px; margin: 0 0 16px; }
    .about-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .astat { padding: 16px 18px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--soft); }
    .astat b    { display: block; font-size: 26px; font-weight: 900; }
    .astat span { display: block; color: var(--muted); font-size: 12px; margin-top: 3px; }

    /* ── PRICING ───────────────────────────────────────── */
    .pricing-band { background: var(--soft); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
    .offer { display: grid; grid-template-columns: .82fr 1.18fr; gap: 16px; align-items: stretch; }
    .price-card { padding: 26px; border-radius: 12px; background: var(--ink); color: white; }
    .price-card .plabel { color: #fca5a5; font-size: 11px; font-weight: 800; text-transform: uppercase; }
    .price-card h2 { margin: 14px 0 10px; font-size: clamp(28px, 4vw, 48px); line-height: .95; }
    .price-card p  { color: #d1d5db; line-height: 1.65; margin: 0 0 20px; font-size: 14px; }
    .offer-list { display: grid; gap: 10px; }
    .offer-row {
      padding: 16px 18px; border: 1px solid var(--line); border-radius: var(--radius);
      background: white; display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;
    }
    .offer-row h3 { margin: 0 0 5px; font-size: 16px; }
    .offer-row p  { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.45; }
    .offer-row strong { color: var(--red); font-size: 15px; white-space: nowrap; }

    /* ── FAQ ───────────────────────────────────────────── */
    .faq-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    .faq { padding: 20px; border: 1px solid var(--line); border-radius: var(--radius); background: white; }
    .faq h3 { margin: 0 0 8px; font-size: 16px; }
    .faq p  { margin: 0; color: var(--muted); line-height: 1.58; font-size: 14px; }

    /* ── CONTACT ───────────────────────────────────────── */
    #contact { scroll-margin-top: 90px; }
    .final-cta {
      padding: 40px; border-radius: 14px; color: white;
      background: linear-gradient(135deg, #17191f 0%, #2b1210 100%);
      display: grid; grid-template-columns: .88fr 1.12fr; gap: 28px; align-items: center;
    }
    .final-cta h2 { margin: 0 0 10px; font-size: clamp(26px, 3.8vw, 44px); line-height: 1; }
    .final-cta p  { margin: 0; color: #d1d5db; line-height: 1.6; font-size: 15px; }
    .contact-email {
      display: inline-flex; align-items: center; gap: 6px; margin-top: 14px;
      padding: 9px 16px; border-radius: 7px; font-size: 13px; font-weight: 700;
      border: 1px solid rgba(255,255,255,.22); color: white;
    }
    .contact-email:hover { background: rgba(255,255,255,.1); }
    .lead-form {
      display: grid; gap: 10px; padding: 18px;
      border: 1px solid rgba(255,255,255,.14); border-radius: 12px;
      background: rgba(255,255,255,.08);
    }
    .lead-form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
    .lead-form label { display: grid; gap: 5px; color: #f9fafb; font-size: 11px; font-weight: 800; text-transform: uppercase; }
    .lead-form input,
    .lead-form select,
    .lead-form textarea {
      width: 100%; border: 1px solid rgba(255,255,255,.18); border-radius: 7px;
      background: rgba(255,255,255,.96); color: var(--ink);
      font: inherit; padding: 10px 11px; outline: none; font-size: 13px;
    }
    .lead-form textarea { min-height: 92px; resize: vertical; }
    .lead-form .full { grid-column: 1 / -1; }
    .lead-form-note { color: #9ca3af; font-size: 11px; line-height: 1.55; margin: 0; }

    /* ── FOOTER ────────────────────────────────────────── */
    .footer { padding: 24px 0 34px; border-top: 1px solid var(--line); color: var(--muted); font-size: 13px; }
    .footer-inner { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; align-items: center; }
    .footer-links { display: flex; gap: 18px; flex-wrap: wrap; }
    .footer-links a:hover { color: var(--red); }

    /* ── RESPONSIVE ────────────────────────────────────── */
    @media (max-width: 960px) {
      .nav-links, .nav-cta { display: none; }
      .menu-toggle { display: flex; }
      .hero { padding-top: 40px; }
      .hero-grid, .offer, .final-cta, .about-grid, .dist-grid { grid-template-columns: 1fr; }
      .studio-board { min-height: auto; }
      .services, .faq-grid { grid-template-columns: 1fr; }
      .process { grid-template-columns: repeat(2, 1fr); }
      .section-head { display: block; }
      .section-head p { margin-top: 12px; }
      .poster-wall { grid-template-columns: repeat(3, 1fr); }
      .feature-card { grid-template-columns: 1fr; }
      .feature-card img { width: 100%; height: 220px; }
    }
    @media (max-width: 560px) {
      .container { width: min(100% - 24px, 1160px); }
      h1 { font-size: 38px; }
      section { padding: 48px 0; }
      .final-cta { padding: 22px; }
      .lead-form-grid { grid-template-columns: 1fr; }
      .offer-row { grid-template-columns: 1fr; }
