<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — Better Than Yesterday Studio</title>
  <meta name="description" content="{{ summary }}">
  {% if keywords %}<meta name="keywords" content="{{ keywords | join(', ') }}">{% endif %}
  <meta property="og:type"        content="article">
  <meta property="og:title"       content="{{ title }} — Better Than Yesterday Studio">
  <meta property="og:description" content="{{ summary }}">
  <meta property="og:image"       content="https://bizuogehao.com/assets/img/logo-mark.png">
  <meta property="og:url"         content="https://bizuogehao.com/en/news/{{ slug }}/">
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="{{ title }}">
  <meta name="twitter:description" content="{{ summary }}">
  <link rel="canonical"                 href="https://bizuogehao.com/en/news/{{ slug }}/">
  <link rel="alternate" hreflang="en"       href="https://bizuogehao.com/en/news/{{ slug }}/">
  <link rel="alternate" hreflang="zh-CN"    href="https://bizuogehao.com/">
  <link rel="alternate" hreflang="x-default" href="https://bizuogehao.com/en/news/{{ slug }}/">
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ title | dump | safe }},
    "description": {{ summary | dump | safe }},
    "datePublished": {{ date | ymd | dump | safe }},
    "dateModified":  {{ (updated if updated else date) | ymd | dump | safe }},
    "author":    {"@id": "https://bizuogehao.com/en/#organization"},
    "publisher": {"@id": "https://bizuogehao.com/en/#organization"},
    "mainEntityOfPage": {"@type":"WebPage","@id":"https://bizuogehao.com/en/news/{{ slug }}/"},
    "url": "https://bizuogehao.com/en/news/{{ slug }}/",
    "inLanguage": "en",
    "keywords": {{ (keywords if keywords else []) | dump | safe }}
  }
  </script>
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
    {"@type":"ListItem","position":1,"name":"Home",    "item":"https://bizuogehao.com/en/"},
    {"@type":"ListItem","position":2,"name":"Insights","item":"https://bizuogehao.com/en/news/"},
    {"@type":"ListItem","position":3,"name": {{ title | dump | safe }} }
  ]}
  </script>
  {% if faq %}
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[
  {%- for item in faq %}
  {"@type":"Question","name":{{ item.q | dump | safe }},"acceptedAnswer":{"@type":"Answer","text":{{ item.a | dump | safe }}}}}{% if not loop.last %},{% endif %}
  {%- endfor %}
  ]}
  </script>
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" media="print" onload="this.media='all'"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap">
  <style>
    :root{--red:#ce3b2b;--ink:#15171c;--muted:#6b7280;--line:#e5e7eb;--soft:#f6f7f9}
    *{box-sizing:border-box}
    body{margin:0;color:var(--ink);background:#fff;font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif}
    a{color:inherit;text-decoration:none}
    img{display:block;max-width:100%}
    /* header */
    .en-header{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.94);border-bottom:1px solid var(--line);backdrop-filter:blur(16px)}
    .en-nav{height:64px;display:flex;align-items:center;justify-content:space-between;gap:20px;width:min(1160px,calc(100% - 40px));margin:0 auto}
    .en-brand{display:flex;align-items:center;gap:9px;color:var(--ink)}
    .en-brand img{width:28px;height:28px}
    .en-brand span{font-size:14px;font-weight:700}
    .en-nav-links{display:flex;gap:16px;font-size:13px;color:#4b5563}
    .en-nav-links a:hover{color:var(--red)}
    .en-nav-cta{padding:6px 14px;background:var(--ink);color:#fff;border-radius:6px;font-size:12px;font-weight:700;white-space:nowrap}
    .en-nav-cta:hover{background:#2d3748}
    /* breadcrumb */
    .en-breadcrumb{padding:10px 0;font-size:12px;color:var(--muted);width:min(1160px,calc(100% - 40px));margin:0 auto}
    .en-breadcrumb a{color:var(--muted)}
    .en-breadcrumb a:hover{color:var(--red)}
    .en-breadcrumb .sep{margin:0 6px}
    /* article */
    .en-article-wrap{width:min(760px,calc(100% - 40px));margin:40px auto 64px}
    .en-article-wrap h1{font-size:clamp(26px,4vw,42px);line-height:1.1;margin:0 0 12px;font-weight:900}
    .en-article-meta{color:var(--muted);font-size:13px;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid var(--line)}
    .en-article-body{font-size:16px;line-height:1.78;color:#374151}
    .en-article-body h2{font-size:22px;font-weight:800;margin:36px 0 14px;color:var(--ink)}
    .en-article-body h3{font-size:17px;font-weight:700;margin:26px 0 10px;color:var(--ink)}
    .en-article-body p{margin:0 0 16px}
    .en-article-body ul,.en-article-body ol{margin:0 0 16px;padding-left:22px}
    .en-article-body li{margin-bottom:6px}
    .en-article-body strong{font-weight:700;color:var(--ink)}
    .en-article-body a{color:var(--red);text-decoration:underline}
    .en-article-body hr{border:none;border-top:1px solid var(--line);margin:28px 0}
    .en-article-body blockquote{margin:24px 0;padding:14px 18px;border-left:3px solid var(--red);background:#fef2f2;border-radius:0 6px 6px 0;font-style:italic}
    .en-article-body table{width:100%;border-collapse:collapse;margin:20px 0;font-size:14px}
    .en-article-body th{background:var(--soft);padding:10px 12px;text-align:left;font-weight:700;border:1px solid var(--line)}
    .en-article-body td{padding:9px 12px;border:1px solid var(--line)}
    .en-article-actions{display:flex;gap:12px;margin-top:36px;flex-wrap:wrap}
    .en-btn{display:inline-flex;align-items:center;padding:10px 20px;border-radius:7px;font-weight:700;font-size:14px}
    .en-btn-primary{background:var(--red);color:#fff}
    .en-btn-ghost{background:var(--soft);color:var(--ink);border:1px solid var(--line)}
    /* footer */
    .en-footer{border-top:1px solid var(--line);padding:22px 0;color:var(--muted);font-size:13px;margin-top:40px}
    .en-footer-inner{width:min(1160px,calc(100% - 40px));margin:0 auto;display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap}
    .en-footer-links{display:flex;gap:16px}
    .en-footer-links a:hover{color:var(--red)}
    @media(max-width:640px){.en-nav-links{display:none}.en-article-wrap{margin-top:24px}}
  </style>
</head>
<body>
  <header class="en-header">
    <div class="en-nav">
      <a class="en-brand" href="/en/">
        <img src="/assets/img/logo-mark.png" alt="Better Than Yesterday Studio">
        <span>Better Than Yesterday Studio</span>
      </a>
      <nav class="en-nav-links" aria-label="Site navigation">
        <a href="/en/#services">Services</a>
        <a href="/en/#slate">Drama Slate</a>
        <a href="/en/news/">Insights</a>
        <a href="/en/#about">About</a>
      </nav>
      <a class="en-nav-cta" href="/en/#contact">Get in Touch</a>
    </div>
  </header>

  <nav class="en-breadcrumb" aria-label="Breadcrumb">
    <a href="/en/">Home</a><span class="sep">/</span>
    <a href="/en/news/">Insights</a><span class="sep">/</span>
    <span>{{ title }}</span>
  </nav>

  <main class="en-article-wrap">
    <h1>{{ title }}</h1>
    <p class="en-article-meta">{{ date | ymd }}{% if author %} · {{ author }}{% endif %}</p>
    <div class="en-article-body">{{ content | safe }}</div>
    <div class="en-article-actions">
      <a class="en-btn en-btn-ghost" href="/en/news/">← Back to Insights</a>
      <a class="en-btn en-btn-primary" href="/en/#contact">Talk to Our Team →</a>
    </div>
  </main>

  <footer class="en-footer">
    <div class="en-footer-inner">
      <span>Better Than Yesterday Studio · 比昨个好文化传媒 · Beijing, China</span>
      <div class="en-footer-links">
        <a href="/en/news/">Insights</a>
        <a href="/en/#contact">Contact</a>
        <a href="mailto:business@bizuogehao.com">business@bizuogehao.com</a>
        <a href="/">中文官网</a>
      </div>
    </div>
  </footer>
</body>
</html>
