</script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://bizuogehao.com/"},{"@type":"ListItem","position":2,"name":"行业观察","item":"https://bizuogehao.com/news/"}]}
</script>
</head>
<body data-page="news">
{% include "header.njk" %}
{{ content | safe }}
{% include "footer.njk" %}
</body>
</html>
