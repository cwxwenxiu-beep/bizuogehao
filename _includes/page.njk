<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:image" content="{{ site.logo }}">
<meta property="og:url" content="{{ site.domain }}{{ page.url }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="{{ site.logo }}">
<link rel="canonical" href="{{ site.domain }}{{ page.url }}">
<link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/style.css">
<link rel="stylesheet" href="/assets/css/news.css">
<script defer src="/assets/js/main.js"></script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Organization","@id":"https://bizuogehao.com/#organization","name":{{ site.company | dump | safe }},"alternateName":["比昨个好文化传媒","比昨个好"],"url":"https://bizuogehao.com/","logo":{{ site.logo | dump | safe }},"email":{{ site.email | dump | safe }},"knowsAbout":["AI短剧出海","短剧出海","达人营销","小红书种草","品牌内容营销"]}
</script>
<script type="application/ld+json">
