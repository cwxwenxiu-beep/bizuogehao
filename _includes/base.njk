<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ (seo_title if seo_title else title + "｜" + site.name) }}</title>
<meta name="description" content="{{ (seo_description if seo_description else summary) }}">
<meta property="og:type" content="article">
<meta property="og:title" content="{{ title }}｜{{ site.name }}">
<meta property="og:description" content="{{ summary }}">
<meta property="og:image" content="{{ (site.domain + cover) if cover else site.logo }}">
<meta property="og:url" content="{{ site.domain }}/news/{{ slug }}/">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="article:published_time" content="{{ date }}">
<meta property="article:section" content="{{ categories[category] }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }}｜{{ site.name }}">
<meta name="twitter:description" content="{{ summary }}">
<meta name="twitter:image" content="{{ (site.domain + cover) if cover else site.logo }}">
<link rel="canonical" href="{{ site.domain }}/news/{{ slug }}/">
<link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/style.css">
<script defer src="/assets/js/main.js"></script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Article","headline":{{ title | dump | safe }},"description":{{ summary | dump | safe }},"image":{{ ((site.domain + cover) if cover else site.logo) | dump | safe }},"datePublished":{{ date | dump | safe }},"dateModified":{{ (updated if updated else date) | dump | safe }},"author":{"@type":"Organization","name":{{ site.company | dump | safe }}},"publisher":{"@type":"Organization","name":{{ site.company | dump | safe }},"logo":{"@type":"ImageObject","url":{{ site.logo | dump | safe }}}},"mainEntityOfPage":{{ (site.domain + "/news/" + slug + "/") | dump | safe }},"articleSection":{{ categories[category] | dump | safe }}}
</script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://bizuogehao.com/"},{"@type":"ListItem","position":2,"name":"行业观察","item":"https://bizuogehao.com/news/"},{"@type":"ListItem","position":3,"name":{{ categories[category] | dump | safe }},"item":{{ (site.domain + "/news/" + category + "/") | dump | safe }}},{"@type":"ListItem","position":4,"name":{{ title | dump | safe }}}]}
</script>
</head>
<body data-page="news">
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/index.html" aria-label="比昨个好文化传媒首页"><img class="brand-logo" src="/assets/img/logo-mark.png" alt="比昨个好文化传媒"><span class="brand-copy"><span class="brand-name">比昨个好文化传媒</span><span class="brand-sub">内容营销 · 短剧出海</span></span></a>
    <nav class="nav" aria-label="主导航"><a href="/index.html">首页</a><a href="/business.html">内容营销</a><a href="/drama.html">短剧出海</a><a href="/about.html">关于我们</a><a href="/contact.html">联系我们</a><a class="active" href="/news.html">行业观察</a></nav>
    <a class="header-cta" href="/contact.html">获取方案</a>
    <button class="menu-toggle" type="button" aria-label="打开菜单" aria-expanded="false"><span></span><span></span><span></span></button>
  </div>
  <div class="mobile-panel" aria-label="移动端菜单"><a href="/index.html">首页</a><a href="/business.html">内容营销</a><a href="/drama.html">短剧出海</a><a href="/about.html">关于我们</a><a href="/contact.html">联系我们</a><a href="/news.html">行业观察</a></div>
</header>
{{ content | safe }}
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand"><img src="/assets/img/logo-mark.png" alt="比昨个好文化传媒">比昨个好文化传媒</div>
    <div class="footer-links"><a href="/about.html">关于我们</a><a href="/news.html">行业观察</a><a href="/privacy.html">隐私</a><a href="/legal.html">法律</a><a href="mailto:business@bizuogehao.com">business@bizuogehao.com</a></div>
  </div>
</footer>
<script defer src="/assets/js/site-config.js"></script>
</body>
</html>
