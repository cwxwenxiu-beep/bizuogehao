<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ (seo_title if seo_title else title + "｜" + site.name) }}</title>
<meta name="description" content="{{ (seo_description if seo_description else summary) }}">
{% if keywords %}<meta name="keywords" content="{{ keywords | join(', ') }}">{% endif %}
<meta property="og:type" content="article">
<meta property="og:title" content="{{ title }}｜{{ site.name }}">
<meta property="og:description" content="{{ summary }}">
<meta property="og:image" content="{{ (site.domain + cover) if cover else site.logo }}">
<meta property="og:url" content="{{ site.domain }}/news/{{ slug }}/">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="article:published_time" content="{{ date | ymd }}">
<meta property="article:section" content="{{ categories[category] }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }}｜{{ site.name }}">
<meta name="twitter:description" content="{{ summary }}">
<meta name="twitter:image" content="{{ (site.domain + cover) if cover else site.logo }}">
<link rel="canonical" href="{{ site.domain }}/news/{{ slug }}/">
<link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/style.css">
<link rel="stylesheet" href="/assets/css/news.css">
<script defer src="/assets/js/main.js"></script>
{% if has_charts %}<script defer src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>{% endif %}
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Article","headline":{{ title | dump | safe }},"description":{{ summary | dump | safe }},"image":{{ ((site.domain + cover) if cover else site.logo) | dump | safe }},"datePublished":{{ date | ymd | dump | safe }},"dateModified":{{ (updated if updated else date) | ymd | dump | safe }},"author":{"@type":"Organization","name":{{ site.company | dump | safe }}},"publisher":{"@type":"Organization","name":{{ site.company | dump | safe }},"logo":{"@type":"ImageObject","url":{{ site.logo | dump | safe }}}},"mainEntityOfPage":{{ (site.domain + "/news/" + slug + "/") | dump | safe }},"articleSection":{{ categories[category] | dump | safe }}}
</script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"首页","item":"https://bizuogehao.com/"},{"@type":"ListItem","position":2,"name":"行业观察","item":"https://bizuogehao.com/news/"},{"@type":"ListItem","position":3,"name":{{ categories[category] | dump | safe }},"item":{{ (site.domain + "/news/" + category + "/") | dump | safe }}},{"@type":"ListItem","position":4,"name":{{ title | dump | safe }}}]}
</script>
</head>
<body data-page="news">
{% include "header.njk" %}
{{ content | safe }}
{% include "footer.njk" %}
</body>
</html>
