---
layout: base.njk
---
<main class="news-page is-article"><div class="container">
  <span class="eyebrow reveal">{{ categories[category] }}</span>
  <h1 class="reveal">{{ title }}</h1>
  <p class="news-meta reveal">{{ date | ymd }}{% if author %} · {{ author }}{% endif %}</p>
  <article class="news-article reveal">
{{ content | safe }}
  </article>
  <div class="actions reveal" style="margin-top:36px"><a class="btn btn-ghost" href="/news/">← 返回行业观察</a><a class="btn btn-primary" href="/contact.html">聊聊合作 <span class="arr">&#8594;</span></a></div>
</div></main>
