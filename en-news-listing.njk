---
permalink: /en/news/index.html
eleventyExcludeFromCollections: true
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Insights — Short Drama Distribution & Production | Better Than Yesterday Studio</title>
  <meta name="description" content="Industry insights on short drama distribution, TikTok strategy, AI production and localization — from Better Than Yesterday Studio in Beijing.">
  <link rel="canonical" href="https://bizuogehao.com/en/news/">
  <link rel="alternate" hreflang="en"        href="https://bizuogehao.com/en/news/">
  <link rel="alternate" hreflang="zh-CN"     href="https://bizuogehao.com/news/">
  <link rel="alternate" hreflang="x-default"  href="https://bizuogehao.com/en/news/">
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[
    {"@type":"ListItem","position":1,"name":"Home",    "item":"https://bizuogehao.com/en/"},
    {"@type":"ListItem","position":2,"name":"Insights","item":"https://bizuogehao.com/en/news/"}
  ]}
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" media="print" onload="this.media='all'"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap">
  <style>
    :root{--red:#ce3b2b;--ink:#15171c;--muted:#6b7280;--line:#e5e7eb;--soft:#f6f7f9}
    *{box-sizing:border-box}
    body{margin:0;color:var(--ink);background:#fff;font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif}
    a{color:inherit;text-decoration:none}
    img{display:block;max-width:100%}
    .en-header{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.94);border-bottom:1px solid var(--line);backdrop-filter:blur(16px)}
    .en-nav{height:64px;display:flex;align-items:center;justify-content:space-between;gap:20px;width:min(1160px,calc(100% - 40px));margin:0 auto}
    .en-brand{display:flex;align-items:center;gap:9px;color:var(--ink)}
    .en-brand img{width:28px;height:28px}
    .en-brand span{font-size:14px;font-weight:700}
    .en-nav-links{display:flex;gap:16px;font-size:13px;color:#4b5563}
    .en-nav-links a:hover{color:var(--red)}
    .en-nav-cta{padding:6px 14px;background:var(--ink);color:#fff;border-radius:6px;font-size:12px;font-weight:700}
    .en-nav-cta:hover{background:#2d3748}
    .container{width:min(1160px,calc(100% - 40px));margin:0 auto}
    .en-news-hero{padding:52px 0 32px;border-bottom:1px solid var(--line)}
    .eyebrow{display:inline-flex;align-items:center;gap:8px;color:var(--red);font-size:12px;font-weight:800;text-transform:uppercase}
    .eyebrow::before{content:"";width:7px;height:7px;border-radius:999px;background:var(--red)}
    .en-news-hero h1{font-size:clamp(34px,5vw,56px);font-weight:900;line-height:.95;margin:14px 0}
    .en-news-hero p{color:var(--muted);font-size:16px;max-width:540px;line-height:1.65;margin:0}
    .en-news-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px;padding:40px 0 60px}
    .en-post-card{border:1px solid var(--line);border-radius:8px;background:#fff;overflow:hidden;transition:box-shadow .18s}
    .en-post-card:hover{box-shadow:0 8px 28px rgba(0,0,0,.09)}
    .en-post-body{padding:20px}
    .en-post-cat{display:inline-block;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;background:var(--soft);color:var(--muted);margin-bottom:10px}
    .en-post-title{font-size:17px;font-weight:700;line-height:1.35;margin:0 0 10px;color:var(--ink)}
    .en-post-summary{font-size:13px;color:var(--muted);line-height:1.6;margin:0 0 14px}
    .en-post-date{font-size:12px;color:#9ca3af}
    .en-news-empty{padding:48px 0;text-align:center;color:var(--muted)}
    .en-footer{border-top:1px solid var(--line);padding:22px 0;color:var(--muted);font-size:13px}
    .en-footer-inner{width:min(1160px,calc(100% - 40px));margin:0 auto;display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap}
    .en-footer-links{display:flex;gap:16px}
    .en-footer-links a:hover{color:var(--red)}
    @media(max-width:760px){.en-news-grid{grid-template-columns:1fr}.en-nav-links{display:none}}
    @media(min-width:561px) and (max-width:960px){.en-news-grid{grid-template-columns:repeat(2,1fr)}}
  </style>
</head>
<body>
  <header class="en-header">
    <div class="en-nav">
      <a class="en-brand" href="/en/">
        <img src="/assets/img/logo-mark.png" alt="Better Than Yesterday Studio">
        <span>Better Than Yesterday Studio</span>
      </a>
      <nav class="en-nav-links" aria-label="Site navigation">
        <a href="/en/#services">Services</a>
        <a href="/en/#slate">Drama Slate</a>
        <a href="/en/news/">Insights</a>
        <a href="/en/#about">About</a>
      </nav>
      <a class="en-nav-cta" href="/en/#contact">Get in Touch</a>
    </div>
  </header>

  <div class="en-news-hero">
    <div class="container">
      <span class="eyebrow">Insights</span>
      <h1>Short Drama<br>Industry Insights</h1>
      <p>Practical guides on distribution, TikTok strategy, AI production, localization and global market trends — from our team in Beijing.</p>
    </div>
  </div>

  <div class="container">
    {%- if collections.enpost and collections.enpost.length > 0 %}
    <div class="en-news-grid">
      {%- for post in collections.enpost | reverse %}
      <a class="en-post-card" href="{{ post.url }}">
        <div class="en-post-body">
          <span class="en-post-cat">{{ post.data.category }}</span>
          <div class="en-post-title">{{ post.data.title }}</div>
          <p class="en-post-summary">{{ post.data.summary }}</p>
          <span class="en-post-date">{{ post.data.date | ymd }}</span>
        </div>
      </a>
      {%- endfor %}
    </div>
    {%- else %}
    <div class="en-news-empty">Articles coming soon.</div>
    {%- endif %}
  </div>

  <footer class="en-footer">
    <div class="en-footer-inner">
      <span>Better Than Yesterday Studio · 比昨个好文化传媒 · Beijing, China</span>
      <div class="en-footer-links">
        <a href="/en/">Home</a>
        <a href="/en/#contact">Contact</a>
        <a href="mailto:business@bizuogehao.com">business@bizuogehao.com</a>
        <a href="/">中文官网</a>
      </div>
    </div>
  </footer>
</body>
</html>
