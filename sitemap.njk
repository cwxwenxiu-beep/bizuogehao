---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site.domain }}/</loc><changefreq>weekly</changefreq><priority>1.0</priority></url>
  <url><loc>{{ site.domain }}/business.html</loc><changefreq>monthly</changefreq><priority>0.9</priority></url>
  <url><loc>{{ site.domain }}/drama.html</loc><changefreq>monthly</changefreq><priority>0.9</priority></url>
  <url><loc>{{ site.domain }}/about.html</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.domain }}/contact.html</loc><changefreq>monthly</changefreq><priority>0.7</priority></url>
  <url><loc>{{ site.domain }}/news/</loc><changefreq>weekly</changefreq><priority>0.8</priority></url>
  {%- for slug in categoryList %}
  <url><loc>{{ site.domain }}/news/{{ slug }}/</loc><changefreq>weekly</changefreq><priority>0.6</priority></url>
  {%- endfor %}
  {%- for post in collections.post %}
  <url><loc>{{ site.domain }}{{ post.url }}</loc><lastmod>{{ (post.data.updated or post.data.date) | ymd }}</lastmod><changefreq>monthly</changefreq><priority>0.7</priority></url>
  {%- endfor %}
  <url><loc>{{ site.domain }}/privacy.html</loc><changefreq>yearly</changefreq><priority>0.3</priority></url>
  <url><loc>{{ site.domain }}/legal.html</loc><changefreq>yearly</changefreq><priority>0.3</priority></url>
</urlset>
